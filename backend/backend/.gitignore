# ========================================
# Backend .gitignore
# ========================================

# Environment variables (CRITICAL - DO NOT COMMIT)
.env
.env.*
!.env.example

# Dependencies
node_modules/
package-lock.json

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*

# Build
dist/
build/

# Database
*.db
*.sqlite
*.sqlite3

# Uploads (if any)
uploads/
temp/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp

# Test coverage
coverage/
.nyc_output/

