# ========================================
# Frontend .gitignore (Next.js)
# ========================================

# Environment variables (CRITICAL - DO NOT COMMIT)
.env
.env.*
!.env.example
.env.local
.env.development
.env.production
.env.test

# Dependencies
node_modules/
package-lock.json

# Next.js build output
.next/
out/
build/

# Production
/build

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Testing
coverage/
.nyc_output/

# Vercel
.vercel

# TypeScript
*.tsbuildinfo
next-env.d.ts

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo

# Misc
*.pem
.cache

