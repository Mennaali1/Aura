# ========================================
# AURA Project Root .gitignore
# ========================================

# Environment variables (CRITICAL - DO NOT COMMIT)
.env
.env.*
!.env.example
.env.local
.env.development
.env.production
.env.test

# Dependencies
node_modules/
package-lock.json

# Build outputs
dist/
build/
out/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# Temporary files
*.tmp
*.temp
.cache/

# Documentation that may contain sensitive info
SESSION_COMPLETE_SUMMARY.md

